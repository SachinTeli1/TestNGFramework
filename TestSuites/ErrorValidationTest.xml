<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Suite" parallel="tests">

	<listeners>
		<listener class-name="script.testcomponents.Listeners" />
	</listeners>

	<test name="Submit Order Test" thread-count="5">
		<groups>
			<run>
				<include name="ErrorHandling" />
			</run>
		</groups>

		<classes>
			<class name="script.test.SubmitOrderTest" />
		</classes>
	</test>

	<test name="Error Validations Test" thread-count="5">
		<classes>
			<class name="script.test.ErrorValidationsTest" />
		</classes>
	</test>

</suite>